import yfinance as yf
import pandas as pd
import matplotlib.pyplot as plt

def backtest_zscore_strategy(ticker, period='1y', window=20, entry_z=2, exit_z=0):
    # 1. جلب البيانات (مثلاً سهم لوسيد أو مؤشر ناسداك)
    data = yf.download(ticker, period=period)
    df = data[['Close']].copy()

    # 2. الحسابات الكمية
    # حساب المتوسط المتحرك والانحراف المعياري
    df['Moving_Average'] = df['Close'].rolling(window=window).mean()
    df['Std_Dev'] = df['Close'].rolling(window=window).std()

    # حساب الـ Z-Score: (السعر الحالي - المتوسط) / الانحراف المعياري
    df['Z_Score'] = (df['Close'] - df['Moving_Average']) / df['Std_Dev']

    # 3. منطق الإشارات (Signals)
    # شراء إذا كان الـ Z-Score أقل من -2 (انحراف سلبي حاد)
    # بيع (خروج) إذا عاد الـ Z-Score إلى 0 (المتوسط)
    df['Signal'] = 0
    df.loc[df['Z_Score'] < -entry_z, 'Signal'] = 1  # إشارة دخول
    df.loc[df['Z_Score'] > exit_z, 'Signal'] = 0   # إشارة خروج (تصفية)

    # تنظيف الإشارات لتحديد نقاط الدخول الفعلية
    df['Position'] = df['Signal'].ffill().fillna(0)
    
    return df

# تشغيل النموذج على مؤشر ناسداك (QQQ) كمثال
ticker_symbol = "QQQ" 
results = backtest_zscore_strategy(ticker_symbol)

# عرض النتائج
print(results.tail(10))

# رسم بياني توضيحي
plt.figure(figsize=(12,6))
plt.plot(results['Z_Score'], label='Z-Score', color='blue')
plt.axhline(y=-2, color='red', linestyle='--', label='Buy Threshold (-2)')
plt.axhline(y=0, color='green', linestyle='--', label='Mean (0)')
plt.title(f'Quantitative Z-Score for {ticker_symbol}')
plt.legend()
plt.show()
import yfinance as yf
import pandas as pd
import numpy as np

class QuantTrader:
    def __init__(self, ticker, capital=10000):
        self.ticker = ticker
        self.capital = capital
        self.data = None
        self.signals = None

    def fetch_data(self, period='2y', interval='1d'):
        """جلب البيانات التاريخية من ناسداك"""
        print(f"جاري جلب بيانات {self.ticker}...")
        self.data = yf.download(self.ticker, period=period, interval=interval)
        return self.data

    def generate_signals(self, window=20, dev_factor=2):
        """تطبيق استراتيجية Bollinger Bands الكمية"""
        df = self.data.copy()
        
        # حساب المتوسط المتحرك والانحراف المعياري
        df['MA'] = df['Close'].rolling(window=window).mean()
        df['STD'] = df['Close'].rolling(window=window).std()
        
        # حساب النطاقات العلوية والسفلية (Bollinger Bands)
        df['Upper'] = df['MA'] + (df['STD'] * dev_factor)
        df['Lower'] = df['MA'] - (df['STD'] * dev_factor)
        
        # منطق التداول: شراء عند كسر النطاق السفلي، بيع عند كسر العلوي
        df['Signal'] = 0
        df.loc[df['Close'] < df['Lower'], 'Signal'] = 1  # شراء
        df.loc[df['Close'] > df['Upper'], 'Signal'] = -1 # بيع
        
        self.signals = df
        return df

    def backtest(self):
        """اختبار الاستراتيجية على البيانات التاريخية"""
        df = self.signals.copy()
        df['Returns'] = df['Close'].pct_change()
        
        # حساب أداء الاستراتيجية (بافتراض التنفيذ في اليوم التالي)
        df['Strategy_Returns'] = df['Signal'].shift(1) * df['Returns']
        
        # حساب التراكمي للأرباح
        df['Cumulative_Market'] = (1 + df['Returns']).cumprod()
        df['Cumulative_Strategy'] = (1 + df['Strategy_Returns']).cumprod()
        
        final_return = (df['Cumulative_Strategy'].iloc[-1] - 1) * 100
        print(f"--- نتيجة الاختبار لـ {self.ticker} ---")
        print(f"العائد الإجمالي للاستراتيجية: {final_return:.2f}%")
        return df

